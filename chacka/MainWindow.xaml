<Window x:Class="chacka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:chacka"
        mc:Ignorable="d"
        Title="Podcast Live Translator" Height="568" Width="1204"
        Closing="Window_Closing">
  <DockPanel>
    <!-- Toolbars -->
    <ToolBarTray DockPanel.Dock="Top">
      
      <ToolBarTray.ContextMenu>
        <ContextMenu>
          <MenuItem x:Name="MenuMainToolbar" Header="Main Toolbar" IsCheckable="True" IsChecked="True" Checked="ToggleToolbar_Click" Unchecked="ToggleToolbar_Click" />
          <MenuItem x:Name="MenuAudioToolbar" Header="Audio Settings" IsCheckable="True" IsChecked="True" Checked="ToggleToolbar_Click" Unchecked="ToggleToolbar_Click" />
          <MenuItem x:Name="MenuLlmsToolbar" Header="LLM Toolbar" IsCheckable="True" IsChecked="True" Checked="ToggleToolbar_Click" Unchecked="ToggleToolbar_Click" />
      </ContextMenu>
      </ToolBarTray.ContextMenu>

      <ToolBar x:Name="MainToolbar" Band="0" BandIndex="0">
        <TextBlock x:Name="DeviceLabel" Text="Device:" VerticalAlignment="Center" Margin="4,0"/>
        <ComboBox x:Name="DevicesCombo" Width="300"
                          DisplayMemberPath="Name" SelectedValuePath="Id"/>
        <Button x:Name="RefreshDevicesBtn" Content="⟳" ToolTip="Refresh devices" Click="RefreshDevices_Click" Padding="6,2"/>
        <Separator/>
        <Button x:Name="StartBtn" Content="▶ Start" Click="Start_Click" Padding="8,2" IsDefault="True"/>
        <Button x:Name="StopBtn"  Content="⏹ Stop"  Click="Stop_Click"  Padding="8,2" IsEnabled="False" IsCancel="True"/>
        <TextBlock x:Name="RecordIndicator" Text="●" Margin="8,0,4,0" VerticalAlignment="Center" FontSize="16" Foreground="Gray"/>
        <CheckBox x:Name="RecordAudioCheckBox" Content="Record"
                  Checked="RecordAudioCheckBox_Changed" Unchecked="RecordAudioCheckBox_Changed" Style="{x:Null}" IsChecked="False"/>
        <Button x:Name="OpenRecordFolderBtn" Content="📂" Padding="6,2" Click="OpenRecordFolderBtn_Click"/>
        <Separator/>
        <TextBlock x:Name="FromLabel" Text="From:" VerticalAlignment="Center" Margin="4,0"/>
        <ComboBox x:Name="SourceLangCombo" Width="100"
                          DisplayMemberPath="Name" SelectedValuePath="Code"/>
        <TextBlock Text="→" VerticalAlignment="Center" Margin="6,0" FontWeight="Bold"/>
        <TextBlock x:Name="ToLabel" Text="To:" VerticalAlignment="Center" Margin="4,0"/>
        <ComboBox x:Name="TargetLangCombo" Width="100"
                          DisplayMemberPath="Name" SelectedValuePath="Code"/>
        <Separator/>
        <TextBlock x:Name="UiLangLabel" Text="UI:" VerticalAlignment="Center" Margin="4,0"/>
        <ComboBox x:Name="UiLanguageCombo" Width="49" SelectionChanged="UiLanguageCombo_SelectionChanged"/>
      </ToolBar>
      <ToolBar x:Name="LLMToolbar" Band="2" BandIndex="2">
        <TextBlock x:Name="LlmLabel" Text="LLM:" VerticalAlignment="Center" Margin="4,0"/>
        <ComboBox x:Name="LlmCombo" Width="120" SelectionChanged="LlmCombo_SelectionChanged" />
        <Separator/>
        <TextBlock x:Name="WhisperLabel" Text="Whisper:" VerticalAlignment="Center" Margin="4,0"/>
        <ComboBox x:Name="WhisperModelCombo" Width="80">
            <ComboBoxItem Content="tiny" />
            <ComboBoxItem Content="base" />
            <ComboBoxItem Content="small" />
            <ComboBoxItem Content="medium" />
            <ComboBoxItem Content="large" />
        </ComboBox>
        <Button x:Name="ApplyWhisperModelBtn" Content="↻" ToolTip="Apply Model" Click="ApplyWhisperModelBtn_Click" Padding="6,2"/>
      </ToolBar>
       <ToolBar x:Name="AudioToolbar" Band="1" BandIndex="0">
        <TextBlock x:Name="PauseDurationLabel" Text="Pause(s):" VerticalAlignment="Center" Margin="0,0,4,0" ToolTip="How many seconds of silence before processing audio chunk"/>
        <Slider x:Name="PauseDurationSlider" Width="100" Minimum="0.10" Maximum="2.00" TickFrequency="0.05"
                          IsSnapToTickEnabled="True" ValueChanged="SettingsSlider_ValueChanged"/>
        <TextBlock x:Name="PauseDurationValueText" Width="38" Margin="4,0,4,0" VerticalAlignment="Center"/>

        <TextBlock x:Name="MinChunkLabel" Text="Min chunk(s):" VerticalAlignment="Center" Margin="0,0,4,0" ToolTip="Minimum seconds to capture before allowing pause interruption"/>
        <Slider x:Name="MinChunkBeforePauseSlider" Width="100" Minimum="0.50" Maximum="3.00" TickFrequency="0.10"
                          IsSnapToTickEnabled="True" ValueChanged="SettingsSlider_ValueChanged"/>
        <TextBlock x:Name="MinChunkBeforePauseValueText" Width="38" Margin="4,0,4,0" VerticalAlignment="Center"/>

        <TextBlock x:Name="SpeechStartLabel" Text="Start thr:" VerticalAlignment="Center" Margin="0,0,4,0" ToolTip="Threshold RMS value to detect start of speech"/>
        <Slider x:Name="SpeechStartThresholdSlider" Width="100" Minimum="0.0005" Maximum="0.1000" TickFrequency="0.0005"
                          IsSnapToTickEnabled="True" ValueChanged="SettingsSlider_ValueChanged"/>
        <TextBlock x:Name="SpeechStartValueText" Width="55" Margin="4,0,4,0" VerticalAlignment="Center"/>

        <TextBlock x:Name="SpeechEndLabel" Text="End thr:" VerticalAlignment="Center" Margin="0,0,4,0" ToolTip="Threshold RMS value to mark the end of speech"/>
        <Slider x:Name="SpeechEndThresholdSlider" Width="100" Minimum="0.0001" Maximum="0.1000" TickFrequency="0.0005"
                          IsSnapToTickEnabled="True" ValueChanged="SettingsSlider_ValueChanged"/>
        <TextBlock x:Name="SpeechEndValueText" Width="55" Margin="4,0,4,0" VerticalAlignment="Center"/>
      </ToolBar>
    </ToolBarTray>

    <StatusBar DockPanel.Dock="Bottom">
      <StatusBarItem>
        <StackPanel Orientation="Horizontal">
          <TextBlock x:Name="RecordPathLabel" Width="Auto" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
        </StackPanel>
      </StatusBarItem>
    </StatusBar>

    <!-- Transcript + Translation -->
    <Grid Margin="4">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <DockPanel Grid.Column="0">
        <TextBlock x:Name="TranscriptHeader" DockPanel.Dock="Top" Text="Transcript (source)" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox x:Name="TranscriptBox" IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" AcceptsReturn="True"
                         Background="#FAFAFA" PreviewMouseWheel="OutputText_PreviewMouseWheel"/>
      </DockPanel>

      <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="LightGray"/>

      <DockPanel Grid.Column="2">
        <TextBlock x:Name="TranslationHeader" DockPanel.Dock="Top" Text="Translation" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox x:Name="TranslationBox" IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" AcceptsReturn="True"
                         Background="#FAFAFA" PreviewMouseWheel="OutputText_PreviewMouseWheel"/>
      </DockPanel>
    </Grid>
  </DockPanel>
</Window>
