<Window x:Class="chacka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:chacka"
        mc:Ignorable="d"
        Title="Podcast Live Translator" Height="568" Width="1204"
        Closing="Window_Closing">
  <DockPanel>
    <!-- Toolbars -->
    <ToolBarTray DockPanel.Dock="Top">
      
      <ToolBarTray.ContextMenu>
        <ContextMenu>
          <MenuItem x:Name="MenuMainToolbar" Header="Main Toolbar" IsCheckable="True" IsChecked="True" Checked="ToggleToolbar_Click" Unchecked="ToggleToolbar_Click" />
          <MenuItem x:Name="MenuAudioToolbar" Header="Audio Settings" IsCheckable="True" IsChecked="True" Checked="ToggleToolbar_Click" Unchecked="ToggleToolbar_Click" />
          <MenuItem x:Name="MenuLlmsToolbar" Header="LLM Toolbar" IsCheckable="True" IsChecked="True" Checked="ToggleToolbar_Click" Unchecked="ToggleToolbar_Click" />
        </ContextMenu>
      </ToolBarTray.ContextMenu>

      <ToolBar x:Name="MainToolbar" Band="0" BandIndex="0">
        <TextBlock x:Name="DeviceLabel" Text="Device:" VerticalAlignment="Center" Margin="4,0"/>
        <ComboBox x:Name="DevicesCombo" Width="300"
                          DisplayMemberPath="Name" SelectedValuePath="Id"/>
        <Button x:Name="RefreshDevicesBtn" Content="⟳" ToolTip="Refresh devices" Click="RefreshDevices_Click" Padding="6,2"/>
        <Button x:Name="OpenFileBtn" Content="🎧" ToolTip="Open audio recording for transcription" Click="OpenFile_Click" Padding="6,2"/>
        <Separator/>
        <Button x:Name="StartBtn" Content="▶ Start" Click="Start_Click" Padding="8,2" IsDefault="True"/>
        <Button x:Name="StopBtn"  Content="⏹ Stop"  Click="Stop_Click"  Padding="8,2" IsEnabled="False" IsCancel="True"/>
        <TextBlock x:Name="RecordIndicator" Text="●" Margin="8,0,4,0" VerticalAlignment="Center" FontSize="16" Foreground="Gray"/>
        <CheckBox x:Name="RecordAudioCheckBox" Content="Record"
                  Checked="RecordAudioCheckBox_Changed" Unchecked="RecordAudioCheckBox_Changed" Style="{x:Null}" IsChecked="False"/>
        <Button x:Name="OpenRecordFolderBtn" Content="📂" Padding="6,2" Click="OpenRecordFolderBtn_Click"/>
        <Separator/>
        <TextBlock x:Name="FromLabel" Text="From:" VerticalAlignment="Center" Margin="4,0"/>
        <ComboBox x:Name="SourceLangCombo" Width="100"
                          DisplayMemberPath="Name" SelectedValuePath="Code"/>
        <TextBlock Text="→" VerticalAlignment="Center" Margin="6,0" FontWeight="Bold"/>
        <TextBlock x:Name="ToLabel" Text="To:" VerticalAlignment="Center" Margin="4,0"/>
        <ComboBox x:Name="TargetLangCombo" Width="100"
                          DisplayMemberPath="Name" SelectedValuePath="Code"/>
        <Separator/>
        <TextBlock x:Name="UiLangLabel" Text="UI:" VerticalAlignment="Center" Margin="4,0"/>
        <ComboBox x:Name="UiLanguageCombo" Width="49" SelectionChanged="UiLanguageCombo_SelectionChanged"/>
      </ToolBar>
      <ToolBar x:Name="WispToolbar" Band="2" BandIndex="2">
          
        <TextBlock x:Name="WhisperLabel" Text="Whisper:" VerticalAlignment="Center" Margin="4,0"/>
        <ComboBox x:Name="WhisperModelCombo" Width="80">
            <ComboBoxItem Content="tiny" />
            <ComboBoxItem Content="base" />
            <ComboBoxItem Content="small" />
            <ComboBoxItem Content="medium" />
            <ComboBoxItem Content="large" />
        </ComboBox>
        <Button x:Name="ApplyWhisperModelBtn" Content="↻" ToolTip="Apply Model" Click="ApplyWhisperModelBtn_Click" Padding="6,2"/>
        <TextBlock x:Name="WhisperTempLabel" Text=" Temp:" VerticalAlignment="Center" Margin="4,0"/>
        <Grid Width="56" Margin="4,0,0,0">
            <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="WhisperTempValueText" Grid.Column="0" VerticalContentAlignment="Center"
                    LostKeyboardFocus="NumericValueTextBox_LostKeyboardFocus" PreviewKeyDown="NumericValueTextBox_PreviewKeyDown"/>
            <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <RepeatButton Grid.Row="0" Content="▲" Padding="0" FontSize="8" Click="NumericSpinButton_Click" Tag="WhisperTempSlider:+"/>
            <RepeatButton Grid.Row="1" Content="▼" Padding="0" FontSize="8" Click="NumericSpinButton_Click" Tag="WhisperTempSlider:-"/>
            </Grid>
            <ScrollBar x:Name="WhisperTempSlider" Visibility="Collapsed" Orientation="Horizontal" Minimum="0" Maximum="1.0" SmallChange="0.1" LargeChange="0.1" ValueChanged="WhisperTempSlider_ValueChanged"/>
        </Grid>
                <!--<Separator Margin="5, 0, 10,0"/>-->
                </ToolBar>
                <ToolBar x:Name="LLMToolbar" Band="2" BandIndex="2">
                    <TextBlock x:Name="LlmLabel" Text="LLM:" VerticalAlignment="Center" Margin="4,0"/>
        <ComboBox x:Name="LlmCombo" Width="120" SelectionChanged="LlmCombo_SelectionChanged" />
        <TextBlock x:Name="LlmTempLabel" Text=" Temp:" VerticalAlignment="Center" Margin="4,0"/>
        <Grid Width="56" Margin="4,0,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
          </Grid.ColumnDefinitions>
          <TextBox x:Name="LlmTempValueText" Grid.Column="0" VerticalContentAlignment="Center"
                   LostKeyboardFocus="NumericValueTextBox_LostKeyboardFocus" PreviewKeyDown="NumericValueTextBox_PreviewKeyDown"/>
          <Grid Grid.Column="1">
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <RepeatButton Grid.Row="0" Content="▲" Padding="0" FontSize="8" Click="NumericSpinButton_Click" Tag="LlmTempSlider:+"/>
            <RepeatButton Grid.Row="1" Content="▼" Padding="0" FontSize="8" Click="NumericSpinButton_Click" Tag="LlmTempSlider:-"/>
          </Grid>
          <ScrollBar x:Name="LlmTempSlider" Visibility="Collapsed" Orientation="Horizontal" Minimum="0" Maximum="2.0" SmallChange="0.1" LargeChange="0.1" ValueChanged="LlmTempSlider_ValueChanged"/>
        </Grid>
          
        
      </ToolBar>
       <ToolBar x:Name="AudioToolbar" Band="1" BandIndex="0">

        <TextBlock x:Name="PauseDurationLabel" Text="Pause(s):" VerticalAlignment="Center" Margin="0,0,4,0" />
        <Grid Width="60" Margin="0,0,4,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
          </Grid.ColumnDefinitions>
          <TextBox x:Name="PauseDurationValueText" Grid.Column="0" VerticalContentAlignment="Center"
                   LostKeyboardFocus="NumericValueTextBox_LostKeyboardFocus" PreviewKeyDown="NumericValueTextBox_PreviewKeyDown"/>
          <Grid Grid.Column="1">
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <RepeatButton Grid.Row="0" Content="▲" Padding="0" FontSize="8" Click="NumericSpinButton_Click" Tag="PauseDurationSlider:+"/>
            <RepeatButton Grid.Row="1" Content="▼" Padding="0" FontSize="8" Click="NumericSpinButton_Click" Tag="PauseDurationSlider:-"/>
          </Grid>
          <ScrollBar x:Name="PauseDurationSlider" Visibility="Collapsed" Orientation="Horizontal" Minimum="0.10" Maximum="2.00" SmallChange="0.01" LargeChange="0.05"
                     ValueChanged="SettingsSlider_ValueChanged"/>
        </Grid>

        <TextBlock x:Name="MinChunkLabel" Text="Min chunk(s):" VerticalAlignment="Center" Margin="0,0,4,0" ToolTip="Minimum seconds to capture before allowing pause interruption"/>
        <Grid Width="60" Margin="0,0,4,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
          </Grid.ColumnDefinitions>
          <TextBox x:Name="MinChunkBeforePauseValueText" Grid.Column="0" VerticalContentAlignment="Center"
                   LostKeyboardFocus="NumericValueTextBox_LostKeyboardFocus" PreviewKeyDown="NumericValueTextBox_PreviewKeyDown"/>
          <Grid Grid.Column="1">
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <RepeatButton Grid.Row="0" Content="▲" Padding="0" FontSize="8" Click="NumericSpinButton_Click" Tag="MinChunkBeforePauseSlider:+"/>
            <RepeatButton Grid.Row="1" Content="▼" Padding="0" FontSize="8" Click="NumericSpinButton_Click" Tag="MinChunkBeforePauseSlider:-"/>
          </Grid>
          <ScrollBar x:Name="MinChunkBeforePauseSlider" Visibility="Collapsed" Orientation="Horizontal" Minimum="0.50" Maximum="20.00" SmallChange="0.50" LargeChange="0.10"
                     ValueChanged="SettingsSlider_ValueChanged"/>
        </Grid>

        <TextBlock x:Name="SpeechStartLabel" Text="Start thr:" VerticalAlignment="Center" Margin="0,0,4,0" ToolTip="Threshold RMS value to detect start of speech"/>
        <Grid Width="78" Margin="0,0,4,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
          </Grid.ColumnDefinitions>
          <TextBox x:Name="SpeechStartValueText" Grid.Column="0" VerticalContentAlignment="Center"
                   LostKeyboardFocus="NumericValueTextBox_LostKeyboardFocus" PreviewKeyDown="NumericValueTextBox_PreviewKeyDown"/>
          <Grid Grid.Column="1">
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <RepeatButton Grid.Row="0" Content="▲" Padding="0" FontSize="8" Click="NumericSpinButton_Click" Tag="SpeechStartThresholdSlider:+"/>
            <RepeatButton Grid.Row="1" Content="▼" Padding="0" FontSize="8" Click="NumericSpinButton_Click" Tag="SpeechStartThresholdSlider:-"/>
          </Grid>
          <ScrollBar x:Name="SpeechStartThresholdSlider" Visibility="Collapsed" Orientation="Horizontal" Minimum="0.0010" Maximum="10.0100" SmallChange="0.0001" LargeChange="0.0005"
                     ValueChanged="SettingsSlider_ValueChanged"/>
        </Grid>

        <TextBlock x:Name="SpeechEndLabel" Text="End thr:" VerticalAlignment="Center" Margin="0,0,4,0" ToolTip="Threshold RMS value to mark the end of speech"/>
        <Grid Width="78" Margin="0,0,4,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
          </Grid.ColumnDefinitions>
          <TextBox x:Name="SpeechEndValueText" Grid.Column="0" VerticalContentAlignment="Center"
                   LostKeyboardFocus="NumericValueTextBox_LostKeyboardFocus" PreviewKeyDown="NumericValueTextBox_PreviewKeyDown"/>
          <Grid Grid.Column="1">
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <RepeatButton Grid.Row="0" Content="▲" Padding="0" FontSize="8" Click="NumericSpinButton_Click" Tag="SpeechEndThresholdSlider:+"/>
            <RepeatButton Grid.Row="1" Content="▼" Padding="0" FontSize="8" Click="NumericSpinButton_Click" Tag="SpeechEndThresholdSlider:-"/>
          </Grid>
          <ScrollBar x:Name="SpeechEndThresholdSlider" Visibility="Collapsed" Orientation="Horizontal" Minimum="0.0000" Maximum="10.010" SmallChange="0.0001" LargeChange="0.0005"
                     ValueChanged="SettingsSlider_ValueChanged"/>
        </Grid>
        <TextBlock x:Name="SilenceThresholdLabel" Text="Silence thr:" VerticalAlignment="Center" Margin="0,0,4,0" ToolTip="Silence Threshold to mark the silance"/>
        <Grid Width="78" Margin="0,0,4,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
          </Grid.ColumnDefinitions>
          <TextBox x:Name="SilenceThresholdText" Grid.Column="0" VerticalContentAlignment="Center"
                   LostKeyboardFocus="NumericValueTextBox_LostKeyboardFocus" PreviewKeyDown="NumericValueTextBox_PreviewKeyDown"/>
          <Grid Grid.Column="1">
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <RepeatButton Grid.Row="0" Content="▲" Padding="0" FontSize="8" Click="NumericSpinButton_Click" Tag="SilenceThresholdSlider:+"/>
            <RepeatButton Grid.Row="1" Content="▼" Padding="0" FontSize="8" Click="NumericSpinButton_Click" Tag="SilenceThresholdSlider:-"/>
          </Grid>
          <ScrollBar x:Name="SilenceThresholdSlider" Visibility="Collapsed" Orientation="Horizontal" Minimum="0.0001" Maximum="1.009" SmallChange="0.0001" LargeChange="0.0005"
                     ValueChanged="SettingsSlider_ValueChanged"/>
        </Grid>
      </ToolBar>
    </ToolBarTray>


        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem HorizontalContentAlignment="Stretch">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Column= "0">
                        <TextBlock x:Name="SessionTimerText" Text="0:00:00" VerticalAlignment="Center" Margin="4,0,8,0"/>
                        <TextBlock x:Name="ActiveRecordIndicator" Text="●" Margin="4,0" VerticalAlignment="Center" FontSize="16" Foreground="Gray"/>
                        <TextBlock x:Name="WhisperModeText" Text="[Whisper-recorder mode]" Foreground="#FF8C00" VerticalAlignment="Center" Margin="4,0" Visibility="Collapsed"/>
                        <TextBlock x:Name="FileProgressText" Text="" Foreground="#0066CC" VerticalAlignment="Center" Margin="4,0" Visibility="Collapsed"/>
                        <TextBlock x:Name="StatusLabel" Width="Auto" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0,0,0"/>
                    </StackPanel>

                    <TextBlock x:Name="CapturedStatusLabel" 
                       FontFamily="Consolas"
                       Grid.Column="1"
                       TextTrimming="CharacterEllipsis" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Right" 
                       Margin="8,0,4,0"/>
                </Grid>
            </StatusBarItem>
        </StatusBar>


    <!-- Transcript + Translation -->
    <Grid Margin="4">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <DockPanel Grid.Column="0">
        <TextBlock x:Name="TranscriptHeader" DockPanel.Dock="Top" Text="Transcript (source)" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox x:Name="TranscriptBox" IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" AcceptsReturn="True"
                         Background="#FAFAFA" PreviewMouseWheel="OutputText_PreviewMouseWheel">
          <TextBox.ContextMenu>
            <ContextMenu>
              <MenuItem x:Name="MenuTranscriptCopy" Header="Copy" Command="ApplicationCommands.Copy"/>
              <MenuItem x:Name="MenuTranscriptSave" Header="Save to File..." Click="MenuTranscriptSave_Click"/>
              <MenuItem x:Name="MenuTranscriptClear" Header="Clear text" Click="MenuTranscriptClear_Click"/>
            </ContextMenu>
          </TextBox.ContextMenu>
        </TextBox>
      </DockPanel>

      <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="LightGray"/>

      <DockPanel Grid.Column="2">
        <TextBlock x:Name="TranslationHeader" DockPanel.Dock="Top" Text="Translation" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox x:Name="TranslationBox" IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" AcceptsReturn="True"
                         Background="#FAFAFA" PreviewMouseWheel="OutputText_PreviewMouseWheel">
          <TextBox.ContextMenu>
            <ContextMenu>
              <MenuItem x:Name="MenuTranslationCopy" Header="Copy" Command="ApplicationCommands.Copy"/>
              <MenuItem x:Name="MenuTranslationSave" Header="Save to File..." Click="MenuTranslationSave_Click"/>
              <MenuItem x:Name="MenuTranslationClear" Header="Clear text" Click="MenuTranslationClear_Click"/>
            </ContextMenu>
          </TextBox.ContextMenu>
        </TextBox>
      </DockPanel>
    </Grid>
  </DockPanel>
</Window>
